# Backend configuration. Copy to `.env` for local (non-Docker) runs.
# When running via docker-compose these are injected by the compose file.

# Application
APP_NAME=RAG
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Auth for managed Redis (e.g. Railway); leave blank for local (no auth).
# REDIS_USER defaults to "default" when a password is set but no user is given.
REDIS_USER=
REDIS_PASSWORD=

# Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Cohere Rerank API key (optional; re-ranking is a no-op when unset).
COHERE_API_KEY=
