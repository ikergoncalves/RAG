# Root environment file for docker-compose. Copy to `.env` to override the
# inline defaults in infra/docker-compose.yml. All values below are optional.

# --- Credentials ---
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag

# --- Published host ports ---
POSTGRES_PORT=5432
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- Runtime ---
ENVIRONMENT=development

# --- Provider credentials (used in later phases) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
